{
  "name": "swyft",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "validate:contracts": "node scripts/validate-contracts.js",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "prepare": "husky",
    "api:dev": "pnpm --filter api dev",
    "api:build": "pnpm --filter api build",
    "api:test": "pnpm --filter api test",
    "api:lint": "pnpm --filter api lint",
    "web:dev": "pnpm --filter web dev",
    "web:build": "pnpm --filter web build",
    "web:test": "pnpm --filter web test",
    "web:lint": "pnpm --filter web lint",
    "sdk:build": "pnpm --filter @swyft/sdk build",
    "sdk:test": "pnpm --filter @swyft/sdk test",
    "sdk:publish": "pnpm --filter @swyft/sdk publish"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "turbo": "^2.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "prisma": "^5.22.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@8.15.0"
}
