# ── Stellar Network ───────────────────────────────────────────────────────────
# "TESTNET" or "PUBLIC"
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET

# ── Soroban RPC URL ───────────────────────────────────────────────────────────
# The Soroban JSON-RPC endpoint used for pool/position queries and swap
# simulations. Falls back to the public Stellar testnet node when unset.
#
# For production, supply a private/dedicated RPC endpoint via your deployment
# secret manager (Vercel env vars, GitHub Actions secret, etc.). Do NOT commit
# a real endpoint with an API key to this file.
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ── MEV-Protected RPC URL (optional) ─────────────────────────────────────────
# An alternate Soroban RPC endpoint that hides transaction details until
# finalization, preventing front-running. Used only when the user enables MEV
# Protection in Swap Settings.
#
# Leave blank to fall back to NEXT_PUBLIC_SOROBAN_RPC_URL when MEV is on.
# Supply via secret in production — never commit the real URL here.
NEXT_PUBLIC_MEV_PROTECTED_RPC_URL=

# ── API Base URL ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
