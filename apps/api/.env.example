# ── Database (Prisma) ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/swyft

# ── Redis (BullMQ + Cache) ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Stellar RPC & Horizon ─────────────────────────────────────────────────────
# Both URLs are REQUIRED. The application validates them at startup and will
# refuse to start if they are missing or malformed.
#
# For production deployments, supply these via CI/CD secrets (e.g. GitHub
# Actions secrets: STELLAR_RPC_URL, HORIZON_URL) — never commit real values.
#
# STELLAR_NETWORK must be one of: testnet | mainnet
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org

# ── Contract Addresses ────────────────────────────────────────────────────────
# POOL_CONTRACT_ID is required for the Horizon event indexer. When left empty
# the indexer starts in a disabled/warn-only mode (safe for local dev).
POOL_CONTRACT_ID=

# ── Token List (optional) ─────────────────────────────────────────────────────
# A Uniswap-compatible token list JSON URL. When set, token metadata is
# enriched on startup and weekly.
TOKEN_LIST_URL=

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
JWT_ISSUER=swyft-api
JWT_AUDIENCE=swyft-client

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3001

# ── Internal API key ──────────────────────────────────────────────────────────
# Protects /admin/* and /metrics/db. Set via secret in production.
INTERNAL_API_KEY=change-me-in-production

# ── DB query monitoring ───────────────────────────────────────────────────────
DB_SLOW_QUERY_THRESHOLD_MS=100

# ── Sentry (optional) ────────────────────────────────────────────────────────
# Leave blank to disable error reporting.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Compression ───────────────────────────────────────────────────────────────
COMPRESSION_LEVEL=6

# ── Webhooks ─────────────────────────────────────────────────────────────────
WEBHOOK_LARGE_SWAP_USD=10000
