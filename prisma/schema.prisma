generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pool {
  id                String   @id @default(cuid())
  token0Address     String
  token1Address     String
  feeTier           Int
  currentSqrtPrice  String
  currentTick       Int
  liquidity         String
  tvl               String
  volume24h         String
  feeApr            String
  currentPrice      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  swaps             Swap[]
  positions         Position[]
  priceCandles      PriceCandle[]

  @@map("pool")
  @@index([token0Address, token1Address])
  @@index([createdAt])
}

model Swap {
  id                String   @id @default(cuid())
  /// Stable on-chain event identifier. This makes event delivery idempotent.
  eventId           String   @unique
  poolId            String
  senderAddress     String
  recipientAddress  String
  amount0           String
  amount1           String
  sqrtPriceAfter    String
  tickAfter         Int
  transactionHash   String
  timestamp         DateTime @default(now())

  // Relations
  pool              Pool     @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@map("swap")
  @@index([poolId])
  @@index([senderAddress])
  @@index([timestamp])
  @@index([transactionHash])
}

model Position {
  id                String   @id @default(cuid())
  poolId            String
  ownerAddress      String
  tokenId           String   // NFT token ID
  lowerTick         Int
  upperTick         Int
  liquidity         String
  feesCollected0    String   @default("0")
  feesCollected1    String   @default("0")
  createdAt         DateTime @default(now())
  closedAt          DateTime?

  // Relations
  pool              Pool     @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@map("position")
  @@index([poolId])
  @@index([ownerAddress])
  @@index([createdAt])
  @@index([closedAt])
  @@unique([poolId, tokenId])
}

model Tick {
  id                   String   @id @default(cuid())
  poolId               String
  tickIndex            Int
  liquidityNet         String
  liquidityGross       String
  feeGrowthOutside0X128 String  @default("0")
  feeGrowthOutside1X128 String  @default("0")
  updatedAt            DateTime @updatedAt

  @@unique([poolId, tickIndex])
  @@index([poolId, tickIndex])
  @@map("tick")
}

model Token {
  id                String   @id @default(cuid())
  address           String   @unique
  symbol            String
  name              String
  decimals          Int
  logoUri           String?

  @@map("token")
}

// #75 — API key authentication
model ApiKey {
  id           String    @id @default(cuid())
  hashedKey    String    @unique
  label        String
  ownerWallet  String
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?
  revoked      Boolean   @default(false)

  @@index([ownerWallet])
  @@map("api_key")
}

// #82 — Webhook notifications
model Webhook {
  id               String            @id @default(cuid())
  ownerWallet      String
  url              String
  eventTypes       String[]
  secret           String?
  largeSwapUsd     Float             @default(10000)
  disabled         Boolean           @default(false)
  consecutiveFails Int               @default(0)
  createdAt        DateTime          @default(now())
  deliveries       WebhookDelivery[]

  @@index([ownerWallet])
  @@map("webhook")
}

model WebhookDelivery {
  id             String   @id @default(cuid())
  webhookId      String
  eventType      String
  responseStatus Int?
  deliveryMs     Int?
  createdAt      DateTime @default(now())
  webhook        Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@map("webhook_delivery")
}

// #81 — OHLCV candle aggregation
model PriceCandle {
  id          String   @id @default(cuid())
  poolId      String
  interval    String
  open        Float
  high        Float
  low         Float
  close       Float
  volumeUsd   Float
  periodStart DateTime
  pool        Pool     @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@unique([poolId, interval, periodStart])
  @@index([poolId, interval])
  @@map("price_candle")
}

model PoolCreated {
  eventId      String   @id
  poolId       String
  tokenA       String
  tokenB       String
  fee          String
  sqrtPriceX96 String
  createdAt    DateTime @default(now())

  @@index([poolId])
  @@map("pool_created")
}

model SwapProcessed {
  eventId      String   @id
  poolId       String
  sender       String
  recipient    String
  amount0      String
  amount1      String
  sqrtPriceX96 String
  liquidity    String
  tick         Int
  createdAt    DateTime @default(now())

  @@index([poolId, createdAt])
  @@map("swap_processed")
}

model PositionMinted {
  eventId    String   @id
  poolId     String
  owner      String
  tickLower  Int
  tickUpper  Int
  liquidity  String
  amount0    String
  amount1    String
  createdAt  DateTime @default(now())

  @@index([poolId])
  @@map("position_minted")
}

model PositionBurned {
  eventId    String   @id
  poolId     String
  owner      String
  tickLower  Int
  tickUpper  Int
  liquidity  String
  amount0    String
  amount1    String
  createdAt  DateTime @default(now())

  @@index([poolId])
  @@map("position_burned")
}

model FeesCollected {
  eventId   String   @id
  poolId    String
  recipient String
  amount0   String
  amount1   String
  createdAt DateTime @default(now())

  @@index([poolId])
  @@map("fees_collected")
}

/// Durable checkpoint for external indexers. A persisted cursor prevents a
/// process restart from silently skipping events that were fetched but not yet
/// handed to BullMQ.
model IndexerCursor {
  id        String   @id
  cursor    String
  updatedAt DateTime @updatedAt

  @@map("indexer_cursor")
}
