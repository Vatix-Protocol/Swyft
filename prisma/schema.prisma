generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PoolCreated {
  id          String   @id @default(cuid())
  eventId     String   @unique
  poolId      String
  tokenA      String
  tokenB      String
  fee         String
  sqrtPriceX96 String
  createdAt   DateTime @default(now())

  @@map("pool_created")
}

model SwapProcessed {
  id        String   @id @default(cuid())
  eventId   String   @unique
  poolId    String
  sender    String
  recipient String
  amount0   String
  amount1   String
  sqrtPriceX96 String
  liquidity String
  tick      Int
  createdAt DateTime @default(now())

  @@map("swap_processed")
}

model PositionMinted {
  id        String   @id @default(cuid())
  eventId   String   @unique
  poolId    String
  owner     String
  tickLower Int
  tickUpper Int
  liquidity String
  amount0   String
  amount1   String
  createdAt DateTime @default(now())

  @@map("position_minted")
}

model PositionBurned {
  id        String   @id @default(cuid())
  eventId   String   @unique
  poolId    String
  owner     String
  tickLower Int
  tickUpper Int
  liquidity String
  amount0   String
  amount1   String
  createdAt DateTime @default(now())

  @@map("position_burned")
}

model FeesCollected {
  id        String   @id @default(cuid())
  eventId   String   @unique
  poolId    String
  recipient String
  amount0   String
  amount1   String
  createdAt DateTime @default(now())

  @@map("fees_collected")
}

model Token {
  id              String   @id @default(cuid())
  contractAddress String   @unique
  symbol          String   @default("UNKNOWN")
  name            String   @default("")
  decimals        Int      @default(7)
  logoUri         String?
  updatedAt       DateTime @updatedAt

  @@map("token")
}

// #75 — API key authentication
model ApiKey {
  id           String    @id @default(cuid())
  hashedKey    String    @unique
  label        String
  ownerWallet  String
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?
  revoked      Boolean   @default(false)

  @@index([ownerWallet])
  @@map("api_key")
}

// #82 — Webhook notifications
model Webhook {
  id               String            @id @default(cuid())
  ownerWallet      String
  url              String
  eventTypes       String[]
  secret           String?
  largeSwapUsd     Float             @default(10000)
  disabled         Boolean           @default(false)
  consecutiveFails Int               @default(0)
  createdAt        DateTime          @default(now())
  deliveries       WebhookDelivery[]

  @@index([ownerWallet])
  @@map("webhook")
}

model WebhookDelivery {
  id             String   @id @default(cuid())
  webhookId      String
  eventType      String
  responseStatus Int?
  deliveryMs     Int?
  createdAt      DateTime @default(now())
  webhook        Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@map("webhook_delivery")
}

// #81 — OHLCV candle aggregation
model PriceCandle {
  id          String   @id @default(cuid())
  poolId      String
  interval    String
  open        Float
  high        Float
  low         Float
  close       Float
  volumeUsd   Float
  periodStart DateTime

  @@unique([poolId, interval, periodStart])
  @@index([poolId, interval])
  @@map("price_candle")
}
